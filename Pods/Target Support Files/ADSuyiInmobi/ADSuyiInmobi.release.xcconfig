CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/ADSuyiInmobi
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/ADMobGenDeviceInfo/ADMobGenDeviceInfo-1.6.9.05261/ios" "${PODS_ROOT}/ADSuyiInmobi/ADSuyiInmobi-7.4.5.05261/ios" "${PODS_ROOT}/ADSuyiKit/ADSuyiKit-0.2.5.05282" "${PODS_ROOT}/ADSuyiLocationManager/ADSuyiLocationManager-0.1.2.05261/ios" "${PODS_ROOT}/ADSuyiNetwork/ADSuyiNetwork-0.1.2.05261/ios" "${PODS_ROOT}/ADSuyiSDK/ADSuyiSDK-3.0.4.05291" "${PODS_ROOT}/InMobiSDK-China"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1 ADSUYI_INMOBI_VERSION=@\"7.4.5.05261\"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/ADSuyiInmobi
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
